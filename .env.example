# =============================================================================
# AI Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- API Keys (required) ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Telegram Bot Tokens (required per agent) ---
TELEGRAM_BOT_TOKEN_PERSONAL=
# TELEGRAM_BOT_TOKEN_CTO=

# --- Postgres (Honcho dependency) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ai_stack

# --- Honcho ---
HONCHO_SECRET_KEY=
# Optional OpenRouter / Ollama model overrides (see docker-compose.yml honcho service)
# HONCHO_SUMMARY_OLLAMA_MODEL=qwen3:8b
# HONCHO_SUMMARY_BACKUP_MODEL=google/gemini-2.0-flash-lite
# HONCHO_DERIVER_MODEL=google/gemini-2.0-flash-lite
# HONCHO_DIALECTIC_MINIMAL_MODEL=google/gemini-2.0-flash-lite
# HONCHO_DIALECTIC_LOW_MODEL=google/gemini-2.0-flash-lite
# HONCHO_DIALECTIC_MEDIUM_MODEL=openai/gpt-4o-mini
# HONCHO_DIALECTIC_HIGH_MODEL=anthropic/claude-3.5-sonnet
# HONCHO_DIALECTIC_MAX_MODEL=anthropic/claude-3.5-sonnet
# HONCHO_DREAM_MODEL=anthropic/claude-3.5-sonnet
# HONCHO_DREAM_DEDUCTION_MODEL=google/gemini-2.0-flash-lite
# HONCHO_DREAM_INDUCTION_MODEL=google/gemini-2.0-flash-lite

# --- Camofox Browser ---
CAMOFOX_API_KEY=
CAMOFOX_ADMIN_KEY=
# CAMOFOX_MAX_SESSIONS=10

# --- Firecrawl ---
FIRECRAWL_API_KEY=
# NUQ queue database (separate from Honcho postgres)
FIRECRAWL_NUQ_USER=firecrawl
FIRECRAWL_NUQ_PASSWORD=
FIRECRAWL_NUQ_DB=firecrawl
# FIRECRAWL_PORT=3002
# FIRECRAWL_NUM_WORKERS=8
# FIRECRAWL_CONCURRENT_REQUESTS=10
# FIRECRAWL_MAX_JOBS=5
# FIRECRAWL_BLOCK_MEDIA=true
# Optional: Ollama models for Firecrawl AI scrape/extract (defaults: qwen3:8b, nomic-embed-text)
# FIRECRAWL_OLLAMA_MODEL=qwen3:8b
# FIRECRAWL_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Firecrawl Proxy (optional) ---
# PROXY_SERVER=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# --- OpenAI (optional, used by Firecrawl for embeddings) ---
# OPENAI_API_KEY=

# --- Mission Control (optional, --profile dashboard) ---
# MC_AUTH_USER=admin
# MC_AUTH_PASS=
# MC_API_KEY=
